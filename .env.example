# Firebase Configuration
# Copy this file to .env and fill in your real credentials
# If left blank, the app will run in MOCK MODE for local testing

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Google Maps API Key (Optional for some platforms, but recommended for Android)
GOOGLE_MAPS_API_KEY=
